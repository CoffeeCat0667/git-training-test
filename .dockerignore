# ========== Version control ==========
.git/
.gitignore
.gitattributes

# ========== Python runtime artifacts ==========
__pycache__/
*.py[cod]
*.so
*.egg-info/

# ========== Virtual environments ==========
venv/
env/
.venv/
.env/

# ========== Test artifacts ==========
.pytest_cache/
.coverage
htmlcov/
.tox/

# ========== IDE config ==========
.vscode/
.idea/
*.swp
*.swo

# ========== Build/output artifacts ==========
build/
dist/
output/
*.log

# ========== Image files (except samples) ==========
*.jpg
*.jpeg
*.png
*.bmp
!examples/sample.jpg
!docs/**/*.png

# ========== Docker files ==========
Dockerfile*
docker-compose*.yml
.dockerignore
